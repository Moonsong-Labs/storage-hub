{
    "name": "@storagehub-sdk/core",
    "version": "0.1.0",
    "description": "StorageHub SDK core",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "wasm/pkg"
    ],
    "scripts": {
        "build": "node ../scripts/build.js && tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist",
        "build:wasm": "wasm-pack build ./wasm --target web --release --out-dir pkg",
        "dev": "node ../scripts/build.js --watch",
        "lint": "eslint \"{src/**/*.ts,src/**/*.tsx}\"",
        "format": "prettier --write \"{src/**/*.ts,src/**/*.tsx}\"",
        "format:check": "prettier --check \"{src/**/*.ts,src/**/*.tsx}\"",
        "test": "vitest",
        "typecheck": "tsc --noEmit",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@polkadot/types": "^10.10.3",
        "@storagehub/wasm": "workspace:*",
        "ethers": "^6.15.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "2.1.4",
        "@types/node": "^20.11.19"
    },
    "engines": {
        "node": ">=23"
    }
}