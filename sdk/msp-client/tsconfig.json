{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "baseUrl": ".",
        "paths": {
            "@storagehub-sdk/core": [
                "../core/dist/index.d.ts"
            ],
            "@storagehub-sdk/core/*": [
                "../core/dist/*"
            ]
        },
        "declaration": true,
        "emitDeclarationOnly": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "dist"
    ]
}