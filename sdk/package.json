{
  "name": "@storagehub-sdk/root",
  "private": true,
  "version": "0.7.1",
  "description": "Workspace root for StorageHub SDK monorepo",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "core",
    "msp-client",
    "e2e",
    "examples/node",
    "examples/nextjs",
    "examples/demo-app"
  ],
  "scripts": {
    "build": "bun run build:core && bun run build:msp-client",
    "build:core": "bun run --filter '@storagehub-sdk/core' build",
    "build:msp-client": "bun run --filter '@storagehub-sdk/msp-client' build",
    "clean": "node scripts/clean.js",
    "coverage": "bun run --filter '@storagehub-sdk/core' coverage -- --run && bun run --filter '@storagehub-sdk/msp-client' coverage -- --run",
    "fmt": "bun run --workspaces --if-present --sequential fmt",
    "fmt:fix": "bun run --workspaces --if-present --sequential fmt:fix",
    "lint": "bun run --workspaces --if-present --sequential lint",
    "lint:fix": "bun run --workspaces --if-present --sequential lint:fix",
    "test": "bun run test:core && bun run test:msp-client",
    "test:core": "bun run --filter '@storagehub-sdk/core' test -- --run",
    "test:msp-client": "bun run --filter '@storagehub-sdk/msp-client' test -- --run",
    "typecheck": "bun run --filter '@storagehub-sdk/core' typecheck && bun run --filter '@storagehub-sdk/msp-client' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.11",
    "lint-staged": "^16.2.5",
    "typescript": "~5.5.4",
    "vitest": "^3.2.4"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "engines": {
    "node": ">=22"
  }
}
