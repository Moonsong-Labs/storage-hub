{
  "name": "storagehub-mono-repo",
  "version": "0.1.0",
  "description": "Mono-repo for StorageHub",
  "main": "index.js",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "api-augment",
    "scripts",
    "types-bundle",
    "test",
    "sdk",
    "sdk/core",
    "sdk/msp-client",
    "sdk/e2e",
    "sdk/examples/node",
    "sdk/examples/nextjs",
    "sdk/examples/demo-app"
  ],
  "scripts": {
    "lint": "bun run --workspaces --if-present --sequential lint",
    "lint:fix": "bun run --workspaces --if-present --sequential lint:fix",
    "fmt": "bun run --workspaces --if-present --sequential fmt",
    "fmt:fix": "bun run --workspaces --if-present --sequential fmt:fix"
  },
  "keywords": [],
  "author": "moonsonglabs",
  "license": "ISC",
  "dependencies": {
    "@biomejs/biome": "2.2.4",
    "typescript": "5.9.2"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "cpu-features",
    "esbuild",
    "protobufjs",
    "ssh2"
  ],
  "overrides": {
    "toml": "3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
